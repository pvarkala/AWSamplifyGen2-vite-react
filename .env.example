# AWS Amplify Configuration
# Copy this file to .env.local and update with your AWS Amplify settings

# AWS Region
VITE_AWS_REGION=ap-south-1

# Amplify App Configuration (from amplify_outputs.json)
VITE_USER_POOL_ID=your-user-pool-id
VITE_USER_POOL_CLIENT_ID=your-user-pool-client-id
VITE_IDENTITY_POOL_ID=your-identity-pool-id
VITE_APPSYNC_URL=your-appsync-url
VITE_APPSYNC_REGION=ap-south-1

# OAuth Providers Configuration
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id

# Redirect URLs
VITE_REDIRECT_SIGN_IN=http://localhost:5173/auth/callback
VITE_REDIRECT_SIGN_OUT=http://localhost:5173/auth/logout

# API Configuration
VITE_API_ENDPOINT=https://api.example.com
VITE_SOCKET_SERVER_URL=wss://socket.example.com

# Feature Flags
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true

# Logging
VITE_LOG_LEVEL=info
